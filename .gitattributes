# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly declare text files
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf

# Binary files - do not modify
*.png binary
*.jpg binary
*.gif binary
*.ico binary
